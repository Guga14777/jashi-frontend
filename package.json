{
  "name": "guga",
  "version": "2.0.0-postgresql",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "npm-run-all -p dev:api dev:web",
    "dev:web": "vite",
    "dev:api": "nodemon server.cjs",
    "dev:frontend": "vite",
    "dev:backend": "node server.cjs",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.cjs",
    "postinstall": "prisma generate || echo 'prisma generate skipped'",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:reset": "prisma migrate reset",
    "migrate:json": "node scripts/migrate-json-to-postgres.js",
    "db:setup": "npm run prisma:generate && npm run prisma:push"
  },
  "dependencies": {
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@prisma/client": "^5.7.0",
    "@supabase/supabase-js": "^2.86.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-validator": "^7.3.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.553.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "node-fetch": "^2.7.0",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.17.2",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.30.1",
    "recharts": "^3.3.0",
    "stripe": "^20.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1",
    "prisma": "^5.7.0",
    "vite": "^5.4.21"
  },
  "overrides": {
    "get-intrinsic": "^1.2.4",
    "call-bind": "^1.0.7",
    "es-define-property": "^1.0.0",
    "set-function-length": "^1.2.2",
    "hasown": "^2.0.2"
  }
}
