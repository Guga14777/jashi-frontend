# ============================================================
# Copy this file to .env and fill in real values for local dev.
# On production, set these as platform environment variables.
# ============================================================

# --- Server basics ---
NODE_ENV=development
HOST=localhost
PORT=5182

# --- CORS (comma-separated; allow your Vite dev server + prod domain) ---
ALLOWED_ORIGINS=http://localhost:5177,http://localhost:5178,https://your-prod-domain.com

# --- Database (PostgreSQL / Supabase) ---
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=your-google-maps-key

# --- JWT Secret (MUST be changed in production) ---
JWT_SECRET=please-generate-a-long-random-string-here

# --- Supabase Storage (optional; for document uploads) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=documents

# ============================================================
# Branding — used by email templates, reset page, etc.
# ============================================================
COMPANY_NAME=Guga
COMPANY_TAGLINE=Reliable vehicle shipping, nationwide.
SUPPORT_EMAIL=support@guga.com
# Public URL of your frontend. The password-reset email builds links off this.
APP_URL=http://localhost:5177
# Absolute URL to the logo shown in emails (email clients can't load relative paths).
LOGO_URL=http://localhost:5177/images/logomercury1.png
BRAND_PRIMARY_COLOR=#0b5fff
BRAND_DARK_COLOR=#0a1f44

# Matching frontend brand vars (optional; Vite reads VITE_*)
VITE_APP_URL=http://localhost:5177
VITE_COMPANY_NAME=Guga
VITE_SUPPORT_EMAIL=support@guga.com
VITE_LOGO_URL=/images/logomercury1.png
VITE_COMPANY_TAGLINE=Reliable vehicle shipping, nationwide.

# ============================================================
# SMTP — real password-reset email delivery
# If these are not set, emails are printed to the server console
# (dev fallback). Set all four to enable real delivery.
# ============================================================
# Example providers:
#   Resend:   host=smtp.resend.com       port=465  user=resend            pass=<API KEY>
#   Brevo:    host=smtp-relay.brevo.com  port=587  user=<login>           pass=<SMTP KEY>
#   SendGrid: host=smtp.sendgrid.net     port=587  user=apikey            pass=<API KEY>
#   SES:      host=email-smtp.us-east-1.amazonaws.com port=587 user=<IAM> pass=<secret>
#   Gmail:    host=smtp.gmail.com        port=465  user=<you@gmail.com>   pass=<app password>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Friendly From address. Must be a domain you've verified with the SMTP provider.
EMAIL_FROM=Guga <support@guga.com>
