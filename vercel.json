{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install --ignore-scripts",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://jashi-frontend-production.up.railway.app/api/:path*"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.ico|vite\\.svg|robots\\.txt|sitemap\\.xml).*)",
      "destination": "/index.html"
    }
  ]
}
